    {
      "parameters": {
        "jsCode": "const correos = $input.all();\nconst ahora = new Date();\nconst DOS_MINUTOS = 2 * 60 * 1000;\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.procesados) staticData.procesados = [];\n\nconst nuevos = correos.filter(item => {\n  const fecha = new Date(item.json.date || item.json.internalDate / 1 || 0);\n  const esNuevo = (ahora - fecha) <= DOS_MINUTOS;\n  const id = item.json.id;\n  const noProcesado = !staticData.procesados.includes(id);\n  return esNuevo && noProcesado;\n});\n\nnuevos.forEach(item => {\n  staticData.procesados.push(item.json.id);\n});\n\n// Limpiar procesados viejos (más de 1 día)\nif (!staticData.procesadosTiempo) staticData.procesadosTiempo = {};\nnuevos.forEach(item => {\n  staticData.procesadosTiempo[item.json.id] = ahora.getTime();\n});\nconst UN_DIA = 24 * 60 * 60 * 1000;\nstaticData.procesados = staticData.procesados.filter(id => {\n  const t = staticData.procesadosTiempo[id];\n  return t && (ahora.getTime() - t) < UN_DIA;\n});\n\nif (nuevos.length === 0) return [];\n\nreturn nuevos.map(item => ({ json: item.json }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [208, 0],
      "id": "a1b2c3d4-wt-0001-0001-000000000003",
      "name": "Filtrar Nuevos"
    },
    {
      "parameters": {
        "jsCode": "const subject = $input.first().json.subject || $input.first().json.Subject || '';\n\nconst match = subject.match(/se ha descargado (.+?)\\.pdf/i);\nconst archivo = match ? match[1].trim() : subject;\nconst equipo = archivo.replace(/\\s+\\d+$/, '').trim();\n\nreturn [{ json: { archivo, equipo, subject } }];\n"
      },
