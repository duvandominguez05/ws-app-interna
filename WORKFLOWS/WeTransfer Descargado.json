    {
      "parameters": {
        "jsCode": "const pedidos = $input.first().json.pedidos;\nconst equipo = $node[\"Extraer Equipo\"].json.equipo.toLowerCase();\nconst archivo = $node[\"Extraer Equipo\"].json.archivo;\n\nconst pedido = pedidos.find(p =>\n  p.equipo && p.equipo.toLowerCase().includes(equipo.toLowerCase()) &&\n  p.estado !== 'enviado-final'\n);\n\nif (!pedido) {\n  return [{ json: { encontrado: false, equipo, archivo } }];\n}\n\nreturn [{ json: {\n  encontrado: true,\n  id: pedido.id,\n  equipo: pedido.equipo,\n  estado: pedido.estado,\n  vendedora: pedido.vendedora,\n  archivo\n}}];\n"
      },
